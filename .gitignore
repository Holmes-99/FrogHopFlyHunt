# Unity3D generated meta files that shouldn't be ignored, keeping this
# section explicit for clarity even though the default `*` rules don't touch .meta
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ================================
# Visual Studio / Rider / VS Code
# ================================
.vs/
.idea/
*.csproj.user

